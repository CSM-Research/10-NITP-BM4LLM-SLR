	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

@ARTICLE{Cong-Lem20253851,
	author = {Cong-Lem, Ngo and Soyoof, Ali and Tsering, Diki},
	title = {A Systematic Review of the Limitations and Associated Opportunities of ChatGPT},
